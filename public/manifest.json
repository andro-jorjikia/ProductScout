{
    "manifest_version": 3,
    "name": "ProductScout",
    "description": "Find better deals for products you are already viewing online.",
    "version": "0.1.0",
    "permissions": ["activeTab", "storage", "scripting"],
    "host_permissions": ["<all_urls>", "http://localhost:3001/*"],
    "action": {
      "default_title": "ProductScout"
    },
    "background": {
      "service_worker": "src/background/service-worker.ts",
      "type": "module"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["src/content/content-script.ts"],
        "run_at": "document_idle"
      }
    ]
  }