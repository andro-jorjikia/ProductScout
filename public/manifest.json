{
    "manifest_version": 3,
    "name": "ProductScout",
    "description": "Find better deals for products you are already viewing online.",
    "version": "0.1.0",
    "permissions": ["activeTab", "storage", "scripting"],
    "host_permissions": ["<all_urls>"],
    "action": {
      "default_popup": "src/popup/index.html",
      "default_title": "ProductScout"
    },
    "background": {
      "service_worker": "src/background/index.ts",
      "type": "module"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["src/content/index.ts"],
        "run_at": "document_idle"
      }
    ]
  }